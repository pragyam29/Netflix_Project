{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-etl-101"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"AzureBlobStorage2_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage2'"
		},
		"Source_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Source'"
		},
		"SourceFact_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'SourceFact'"
		},
		"adls_con_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adls_con'"
		},
		"con_netflixdb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'con_netflixdb'"
		},
		"adls_con_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stgadlsnetflix.dfs.core.windows.net/"
		},
		"con_netflixdb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "netflixserver.database.windows.net"
		},
		"con_netflixdb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "netflix_metadata_db"
		},
		"con_netflixdb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Pragya"
		},
		"github_con_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-etl-101_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"AzureBlobStorage2_connectionString": {
						"value": "[parameters('AzureBlobStorage2_connectionString')]"
					},
					"Source_connectionString": {
						"value": "[parameters('Source_connectionString')]"
					},
					"SourceFact_connectionString": {
						"value": "[parameters('SourceFact_connectionString')]"
					},
					"adls_con_accountKey": {
						"value": "[parameters('adls_con_accountKey')]"
					},
					"con_netflixdb_password": {
						"value": "[parameters('con_netflixdb_password')]"
					},
					"adls_con_properties_typeProperties_url": {
						"value": "[parameters('adls_con_properties_typeProperties_url')]"
					},
					"con_netflixdb_properties_typeProperties_server": {
						"value": "[parameters('con_netflixdb_properties_typeProperties_server')]"
					},
					"con_netflixdb_properties_typeProperties_database": {
						"value": "[parameters('con_netflixdb_properties_typeProperties_database')]"
					},
					"con_netflixdb_properties_typeProperties_userName": {
						"value": "[parameters('con_netflixdb_properties_typeProperties_userName')]"
					},
					"github_con_properties_typeProperties_url": {
						"value": "[parameters('github_con_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}